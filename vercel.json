{
  "version": 2,
  "name": "shipgo-gps-tracking",
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/live", "destination": "/live-tracking.html" },
    { "source": "/history", "destination": "/history-tracking.html" },
    { "source": "/shipment", "destination": "/shipment-planning.html" },
    { "source": "/roles", "destination": "/group-role.html" },
    { "source": "/users", "destination": "/user-management.html" },
    { "source": "/config", "destination": "/feature-config.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
